<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="wireguide"
        Arguments=""
        InstallLocation="C:\Program Files\WireGuide">
    </Installer>
    <PackageInformation
        PackageName="WireGuide"
        PackageDisplayName="WireGuide"
        PublisherName="CN=korjwl1"
        PublisherDisplayName="korjwl1"
        Version="0.3.1.0"
        PackageDescription="Cross-platform WireGuard VPN desktop client">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.korjwl1.wireguide"
                Description="Cross-platform WireGuard VPN desktop client"
                DisplayName="WireGuide"
                ExecutableName="wireguide"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>WireGuide</DisplayName>
            <PublisherDisplayName>korjwl1</PublisherDisplayName>
            <Description>Cross-platform WireGuard VPN desktop client</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="wireguide.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
