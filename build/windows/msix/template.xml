<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="wireguide.exe"
        Arguments=""
        InstallLocation="C:\Program Files\WireGuide">
    </Installer>
    <PackageInformation
        PackageName="WireGuide"
        PackageDisplayName="WireGuide"
        PublisherName="CN=WireGuide"
        PublisherDisplayName="WireGuide"
        Version="0.1.5.0"
        PackageDescription="WireGuide - WireGuard VPN Client">
        <Capabilities>
            <Capability Name="runFullTrust" />

        </Capabilities>
        <Applications>
            <Application
                Id="com.wireguide.app"
                Description="WireGuide - WireGuard VPN Client"
                DisplayName="WireGuide"
                ExecutableName="wireguide.exe"
                EntryPoint="Windows.FullTrustApplication">

            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>WireGuide</DisplayName>
            <PublisherDisplayName>WireGuide</PublisherDisplayName>
            <Description>WireGuide - WireGuard VPN Client</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="wireguide.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
